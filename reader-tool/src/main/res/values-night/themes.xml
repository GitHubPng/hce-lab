<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.HceLabReader" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#A5B4FC</item>
        <item name="colorOnPrimary">#1E1B4B</item>
        <item name="colorPrimaryContainer">#312E81</item>
        <item name="colorOnPrimaryContainer">#E0E7FF</item>
        <item name="colorSecondary">#67E8F9</item>
        <item name="colorOnSecondary">#083344</item>
        <item name="colorSecondaryContainer">#155E75</item>

        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_muted_dark</item>

        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Widget.HceLab.SectionCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="contentPadding">18dp</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">#22FFFFFF</item>
        <item name="android:layout_marginBottom">14dp</item>
    </style>
</resources>
