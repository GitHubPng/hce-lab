<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema claro (padrão). O tema escuro fica em values-night/themes.xml
         com os mesmos nomes de atributo, então o sistema troca sozinho
         conforme o modo do aparelho. -->
    <style name="Theme.HceLabReader" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/indigo</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/indigo_light</item>
        <item name="colorOnPrimaryContainer">@color/indigo_dark</item>
        <item name="colorSecondary">@color/cyan</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/cyan_light</item>

        <item name="android:colorBackground">@color/bg_light</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/on_surface_light</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_muted_light</item>

        <item name="android:statusBarColor">@color/indigo</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Widget.HceLab.SectionCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="contentPadding">18dp</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">#14000000</item>
        <item name="android:layout_marginBottom">14dp</item>
    </style>
</resources>
